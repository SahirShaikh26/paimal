{
  "expo": {
    "name": "Paimal",
    "slug": "fieldpilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fieldpilot.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.fieldpilot.mobile",
      "versionCode": 5,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Paimal needs location for check-in."
        }
      ],
      "expo-document-picker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Paimal needs photo library access so you can attach photos to activity logs.",
          "cameraPermission": "Paimal needs camera access so you can take photos of completed work."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Paimal needs microphone access so you can dictate activity notes by voice.",
          "speechRecognitionPermission": "Paimal needs speech recognition access to convert your dictated notes into text."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "95941205-795d-4491-a2e7-4bedf2c6e230"
      }
    }
  }
}
