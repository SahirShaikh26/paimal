# Backend API base URL. Leave unset in production — vercel.json proxies /api to
# the paimal-api Vercel project, so the app calls its own origin.
VITE_API_URL=http://localhost:4000/api

# Monitoring (optional — leave unset to skip Sentry in the webapp)
VITE_SENTRY_DSN=

# Comma-separated emails allowed to see the Status nav item (mirror backend OWNER_EMAILS)
VITE_OWNER_EMAILS=you@example.com

# Razorpay Standard Checkout — the PUBLIC key id only (rzp_test_... / rzp_live_...).
# The KEY_SECRET is backend-only and must never appear here or in the browser.
VITE_RAZORPAY_KEY_ID=
